-- Complex SQL template examples for tamuno-sqlgen
-- Demonstrates: JOINs, subqueries, GROUP BY, HAVING, ORDER BY,
-- pagination, dynamic table names, nested optionals, stop-combiners,
-- multiple combiners, and more.

-- Dynamic table query with literal variable for table name
selectFromDynamic:=
    SELECT @id:int, @name:String
        FROM #table_name
            [ WHERE
                [name=$name] [AND] [active=$active:int]
            ]
        ORDER BY id;

-- Multi-table JOIN with optional filters on each table
searchOrders:=
    SELECT @order_id:int, @customer_name:String, @product_name:String,
           @quantity:int, @unit_price:double, @order_date:Date
        FROM orders o
        JOIN customers c ON o.customer_id = c.customer_id
        JOIN order_items oi ON o.order_id = oi.order_id
        JOIN products p ON oi.product_id = p.product_id
            [ WHERE
                [c.customer_name=$customer_name]
                [AND]
                [p.category=$category]
                [AND]
                [o.order_date >= $date_from:Date]
                [AND]
                [o.order_date <= $date_to:Date]
                [AND]
                [o.status=$status]
            ]
        ORDER BY o.order_date DESC;

-- Aggregation with GROUP BY and optional HAVING
salesReport:=
    SELECT @category:String, @total_revenue:double,
           @order_count:int, @avg_price:double
        FROM products p
        JOIN order_items oi ON p.product_id = oi.product_id
        JOIN orders o ON oi.order_id = o.order_id
            [ WHERE
                [o.order_date >= $date_from:Date]
                [AND]
                [o.order_date <= $date_to:Date]
                [AND]
                [o.status=$status]
            ]
        GROUP BY p.category
            [ HAVING
                [SUM(oi.quantity * oi.unit_price) >= $min_revenue:double]
                [AND]
                [COUNT(DISTINCT o.order_id) >= $min_orders:int]
            ]
        ORDER BY total_revenue DESC;

-- Pagination with LIMIT/OFFSET using literal vars
paginatedProducts:=
    SELECT @product_id:int, @product_name:String, @category:String,
           @price:double, @stock:int
        FROM products
            [ WHERE
                [category=$category]
                [AND]
                [price >= $min_price:double]
                [AND]
                [price <= $max_price:double]
                [AND]
                [stock > $min_stock:int]
            ]
        ORDER BY #sort_column #sort_direction
        LIMIT #page_size OFFSET #page_offset;

-- Complex UPDATE with many optional SET fields and stop-combiner
updateProduct:=
    UPDATE products SET
        [product_name=$product_name] [,]
        [category=$category] [,]
        [price=$price:double] [,]
        [stock=$stock:int] [,]
        [description=$description]
    WHERE product_id=$product_id:int;

-- INSERT with subquery (insert from select)
copyOrderItems:=
    INSERT INTO #target_table (order_id, product_id, quantity, unit_price)
        SELECT oi.order_id, oi.product_id, oi.quantity, oi.unit_price
            FROM order_items oi
            JOIN orders o ON oi.order_id = o.order_id
            WHERE o.status=$status
                [AND o.order_date >= $date_from:Date]
                [AND o.order_date <= $date_to:Date];

-- DELETE with optional conditions
deleteOrders:=
    DELETE FROM orders
        [ WHERE
            [status=$status]
            [AND]
            [order_date < $before_date:Date]
            [AND]
            [customer_id=$customer_id:int]
        ];

-- Nested optional: optional JOIN with optional filter on joined table
customerDetails:=
    SELECT @customer_id:int, @customer_name:String, @email:String
        [, @total_orders:int]
        FROM customers c
        [ LEFT JOIN (
            SELECT customer_id, COUNT(*) as total_orders
            FROM orders GROUP BY customer_id
          ) o ON c.customer_id = o.customer_id]
        [ WHERE
            [c.customer_name LIKE $name_pattern]
            [AND]
            [c.email LIKE $email_pattern]
        ]
        ORDER BY c.customer_name;

-- Multiple stop-combiners to create independent filter groups
advancedSearch:=
    SELECT @id:int, @name:String, @category:String, @price:double
        FROM products
        [ WHERE
            [name LIKE $name_pattern]
            {}
            [AND category=$category]
            {}
            [AND price >= $min_price:double]
            [AND]
            [price <= $max_price:double]
        ];

-- Batch insert with option variable for metadata
batchInsertProducts:=
    INSERT INTO products (product_name, category, price, stock, description)
        VALUES ($product_name, $category, $price:double, $stock:int, $description)
        ?batch_id:String;
